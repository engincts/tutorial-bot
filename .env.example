# ── LLM Provider ──────────────────────────────────────────────
# Seçenekler: openai | anthropic | novita
LLM_PROVIDER=novita

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5

NOVITA_API_KEY=...
NOVITA_LLM_MODEL=meta-llama/llama-3.1-8b-instruct

# ── Embedder Provider ─────────────────────────────────────────
# Seçenekler: openai | novita  (bge_m3 kaldırıldı — cloud-only)
EMBEDDER_PROVIDER=novita
NOVITA_EMBEDDING_MODEL=baai/bge-m3
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=1024

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tutorbot
POSTGRES_USER=tutorbot
POSTGRES_PASSWORD=tutorbot_dev

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
SESSION_TTL_SECONDS=3600

# ── Supabase (Auth) ───────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...
SUPABASE_JWT_SECRET=super-secret-jwt-secret

# ── Knowledge Tracing ─────────────────────────────────────────
# Seçenekler: akt | dkt
KT_MODEL=dkt

# ── Retrieval ─────────────────────────────────────────────────
CONTENT_TOP_K=5
MEMORY_TOP_K=3
RERANK_ENABLED=false

# ── Pedagogy Thresholds ───────────────────────────────────────
MASTERY_THRESHOLD_LOW=0.4
MASTERY_THRESHOLD_HIGH=0.7

# ── App ───────────────────────────────────────────────────────
# Seçenekler: development | production | test
APP_ENV=development
LOG_LEVEL=INFO
