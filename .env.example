# ── LLM Provider ─────────────────────────────────────────────
# "openai" veya "anthropic"
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── Embedder ──────────────────────────────────────────────────
# "bge_m3" (self-hosted, Türkçe güçlü) veya "openai"
EMBEDDER_PROVIDER=bge_m3
EMBEDDER_MODEL=BAAI/bge-m3
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=1024

# ── PostgreSQL + pgvector ─────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tutorbot
POSTGRES_USER=tutorbot
POSTGRES_PASSWORD=tutorbot_dev

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
SESSION_TTL_SECONDS=3600

# ── Knowledge Tracing ─────────────────────────────────────────
# "akt" veya "dkt"
KT_MODEL=akt
KT_MODEL_PATH=./checkpoints/akt_assistments.pt

# ── Retrieval ─────────────────────────────────────────────────
CONTENT_TOP_K=5
MEMORY_TOP_K=3
RERANK_ENABLED=false

# ── Pedagogy ──────────────────────────────────────────────────
MASTERY_THRESHOLD_LOW=0.4
MASTERY_THRESHOLD_HIGH=0.7

# ── App ───────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
